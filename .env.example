# Chave criada no Google AI Studio. Mantenha somente no ambiente do servidor.
GEMINI_API_KEY=cole_sua_chave_aqui

# Modelo visual principal. O backend usa Gemini 3.1 Flash-Lite como fallback.
GEMINI_MODEL=gemini-3.5-flash

# Origens autorizadas, separadas por vírgula. Ajuste para sua publicação.
ALLOWED_ORIGINS=http://localhost:3000,https://rafaelfrancis09.github.io

# Limite simples por instância para reduzir abuso e consumo de cota.
MAX_REQUESTS_PER_MINUTE=10
